# =============================================================================
# CopLLM — Umgebungsvariablen
# Kopiere diese Datei nach .env und trage die echten Werte ein:
#   cp .env.example .env
# =============================================================================

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Ollama (lokales LLM + Embedding) ---
# Fuer Docker: http://host.docker.internal:11434
# Fuer Raspberry Pi im Netz: http://192.168.x.x:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Benoetigte Modelle:
#   ollama pull llama3.3
#   ollama pull nomic-embed-text

# --- LiteLLM ---
LITELLM_MASTER_KEY=sk-litellm-xxxxx
LITELLM_PORT=4000
# Pflicht fuer Virtual Keys + Demo-Budget-Limits (Supabase PostgreSQL URL)
LITELLM_DATABASE_URL=postgresql://postgres.xxxxx:password@db.xxxxx.supabase.co:5432/postgres

# --- Supabase (Region: eu-central-1 / Frankfurt) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
SUPABASE_DB_URL=postgresql://postgres.xxxxx:password@db.xxxxx.supabase.co:5432/postgres

# --- Open WebUI ---
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=change-me-to-random-secret
# Branding (wird in allen WebUI-Instanzen gesetzt)
WEBUI_NAME=CLX Digital KI

# --- Multi-Kunden Secrets (fuer docker-compose.multi.yml) ---
OPENWEBUI_SECRET_CLX=change-me-clx
OPENWEBUI_SECRET_KUNDE_A=change-me-kunde-a
OPENWEBUI_SECRET_KUNDE_B=change-me-kunde-b
# Pro Kunde einen eigenen Secret Key generieren:
#   openssl rand -hex 32

# --- Caddy (nur Weg C: Enterprise) ---
DOMAIN=ai.kundendomaene.de
CADDY_EMAIL=admin@kundendomaene.de

# --- Embedding-Konfiguration ---
# Provider: ollama (lokal), google, openai
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
CHUNK_SIZE=500
CHUNK_OVERLAP=75

# Google Embedding API (wenn EMBEDDING_PROVIDER=google)
# Modelle:
#   gemini-embedding-001        — Nur Text, stabil, $0.15/1M Tokens
#   gemini-embedding-2-preview  — Multimodal (Text+PDF+Bild), $0.20/1M Tokens
#                                  Kann gescannte PDFs direkt embedden (kein OCR noetig!)
# Default-Dimensionen: 3072, konfigurierbar 128-3072
# Fuer Kompatibilitaet mit nomic-embed-text Schema: output_dimensionality=768
GOOGLE_AI_API_KEY=AIzaSyXXXXX
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
# Oder fuer gescannte Dokumente:
# GOOGLE_EMBEDDING_MODEL=gemini-embedding-2-preview

# OpenAI Embedding API (wenn EMBEDDING_PROVIDER=openai)
# Modell: text-embedding-3-small (1536 Dim. → Schema anpassen!)
OPENAI_API_KEY=sk-xxxxx

# --- n8n (Raspberry Pi) ---
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=xxxxx

# --- Google Drive API ---
GOOGLE_DRIVE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=GOCSPXxxxxx
GOOGLE_DRIVE_FOLDER_ID=1ABCxxxxx
GOOGLE_DRIVE_REFRESH_TOKEN=1//xxxxx

# --- OneDrive / Microsoft Graph API ---
ONEDRIVE_CLIENT_ID=xxxxx-xxxxx-xxxxx
ONEDRIVE_CLIENT_SECRET=xxxxx
ONEDRIVE_TENANT_ID=xxxxx
ONEDRIVE_FOLDER_PATH=/CopLLM/Dokumente
ONEDRIVE_REFRESH_TOKEN=xxxxx

# --- Telegram Benachrichtigungen ---
TELEGRAM_BOT_TOKEN=123456:ABCxxxxx
TELEGRAM_CHAT_ID=-100xxxxx

# --- Alerting (LiteLLM Kosten-Monitoring) ---
# Slack Webhook fuer Kosten-Alerts (optional)
# Anleitung: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx/xxxxx/xxxxx

# --- Demo-Account Einstellungen ---
# Werte werden in provision.py und expire-demos.py verwendet
DEMO_DAILY_BUDGET_EUR=0.50
DEMO_DURATION_DAYS=7
DEMO_MAX_FILES=10
